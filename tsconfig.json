{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",           // Changed from "CommonJS"
    "moduleResolution": "bundler", // Changed from "node"
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": false,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}